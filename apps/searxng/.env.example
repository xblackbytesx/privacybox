DOMAIN=privacy.box
SUBDOMAIN=search
CERT_RESOLVER=transip-dns

# Generate one with:  openssl rand -hex 32
SEARXNG_SECRET=

# Proxy image thumbnails through SearXNG so browsers never hit third-party image
# hosts. Privacy win, small bandwidth cost.
SEARXNG_IMAGE_PROXY=true

# Not recommended to change these as these defaults are sound
SEARXNG_LIMITER=false
SEARXNG_METHOD=POST

DOCKER_ROOT=/media/storage/docker
