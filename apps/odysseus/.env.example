DOMAIN=privacy.box
SUBDOMAIN=odysseus
CERT_RESOLVER=cloudflare-dns

PUID=1000
PGID=1000

# ---- Auth & security ----
# First admin, seeded on first boot. Set a password BEFORE the first start.
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=secret
AUTH_ENABLED=true
# Served through Traefik over HTTPS, so keep these on.
SECURE_COOKIES=true
ALLOWED_ORIGINS=https://odysseus.privacy.box
# Dev-only loopback bypass — keep false behind a reverse proxy.
LOCALHOST_BYPASS=false

# ---- LLM providers ----
LLM_HOST=localhost
# Comma-separated extra hosts to scan for served models (incl. Ollama :11434).
# LLM_HOSTS=llm-host.local,backup-llm.local
# Host Ollama (start it with OLLAMA_HOST=0.0.0.0:11434):
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=
# RESEARCH_LLM_ENDPOINT=http://localhost:8000/v1/chat/completions
# HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# ---- Search ----
# You already run SearXNG in PrivacyBox — point Odysseus at it. Use the public
# URL, or the container name if searx is attached to the `proxy` network.
SEARXNG_INSTANCE=https://searx.privacy.box
# Optional web-search API keys:
# DATA_BRAVE_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_PSE_CX=
# TAVILY_API_KEY=
# SERPER_API_KEY=

# ---- Database ----
# Default is SQLite inside the data volume.
# DATABASE_URL=sqlite:///./data/app.db

# ---- RAG / embeddings ----
# EMBEDDING_URL=http://host.docker.internal:11434/v1/embeddings
# EMBEDDING_MODEL=all-minilm:l6-v2
# EMBEDDING_API_KEY=
FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# FASTEMBED_CACHE_PATH=

# ---- Misc ----
# CLEANUP_INTERVAL_HOURS=24
# ODYSSEUS_INPROCESS_POLLERS=1
# ODYSSEUS_INPROCESS_TASKS=1
# ODYSSEUS_SCRIPT_HOST=localhost
# ODYSSEUS_CHAT_UPLOAD_MAX_BYTES=10485760

DOCKER_ROOT=/media/storage/docker
