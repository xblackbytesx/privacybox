DOMAIN=privacy.box
SUBDOMAIN=tabidachi
CERT_RESOLVER=cloudflare-dns

DOCKER_ROOT=/media/storage/docker

# generate using `openssl rand -base64 32`
SESSION_SECRET=secret

# generate using `openssl rand -base64 32`
CSRF_AUTH_KEY=secret

DB_PASSWORD=secret

APP_BASE_URL=https://tabidachi.privacy.box

# Optional: set to "false" only if running without HTTPS (not recommended for production)
SECURE_COOKIES=true

# Set to false to prevent new user registrations (after initial setup)
ALLOW_REGISTRATION=true

# Optional: cover image providers (leave blank to use Wikipedia fallback only)
# Free key at pexels.com/api
PEXELS_API_KEY=

# Free key at unsplash.com/developers
UNSPLASH_ACCESS_KEY=
